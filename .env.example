# Copie ce fichier vers .env et remplis les valeurs (ne jamais committer .env)

# Supabase — Project Settings > API dans le dashboard Supabase
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Stripe Connect — Dashboard Stripe > Développeurs > Clés API
# La clé publique (pk_) est exposée dans l'app mobile (préfixe EXPO_PUBLIC_)
# La clé secrète (sk_) ne va JAMAIS dans l'app mobile — uniquement dans les Edge Functions Supabase
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
